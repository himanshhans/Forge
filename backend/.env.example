# Copy to .env for local dev. Prod sets real env vars.

# --- Django ---
DEBUG=True
SECRET_KEY=dev-insecure-change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (Neon; or local docker-compose Postgres) ---
# Neon: copy the POOLED connection string from the Neon dashboard. Keep ?sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/forge?sslmode=require

# --- Redis (optional in dev) ---
# Leave EMPTY for dev: LocMem cache + Celery eager (no Redis needed).
# Set for prod/async: redis://localhost:6379/0
REDIS_URL=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Auth: Clerk (Django verifies, does NOT issue) ---
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-app.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=
CLERK_SECRET_KEY=

# --- LLM (verify GROQ_MODEL against live catalog) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
TOGETHER_AI_API_KEY=

# --- Avatar generation ---
REPLICATE_API_KEY=
READYPLAYER_API_KEY=

# --- Publishing (wildcard-serve) ---
PORTFOLIO_WILDCARD_DOMAIN=forge.app

# --- Storage (Cloudflare R2, S3-compatible) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=auto

# --- Free-tier limits (default 1 each in prod; raise locally for testing) ---
FREE_PLAN_MAX_PORTFOLIOS=1
FREE_PLAN_MAX_INTRO_CARDS=1
